# PromptNFT 백엔드 환경변수
# .env.example → .env 로 복사 후 값 입력

# Alchemy Sepolia RPC URL
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# 배포된 PromptNFT 컨트랙트 주소
CONTRACT_ADDRESS=0x4187Cf6910659B75D9e90072304A5721A3Ef0E5b

# AES-256 암호화 키 (32바이트 = 64자 HEX)
ENCRYPT_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# 서버 포트
PORT=3001

# 프론트엔드 URL (CORS)
FRONTEND_URL=http://localhost:5173

# 데모 모드 (true: 블록체인 검증 스킵)
DEMO_MODE=true

# OpenAI API (실제 AI 실행용, 비워두면 데모 응답)
OPENAI_API_KEY=sk-xxxx
OPENAI_MODEL=gpt-3.5-turbo

# 로그 레벨 (info, warn, error, debug)
LOG_LEVEL=info
